# ─────────────────────────────────────────────────────────────────────────────
# ObservaAI — root environment template
#
# Copy to `.env` and fill in your provider API keys.
#   cp .env.example .env
#
# Only the providers you actually use need keys. Empty values are fine.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gateway (FastAPI) ────────────────────────────────────────────────────────
DEBUG=false
DATABASE_URL=sqlite+aiosqlite:///./observaai.db

# Provider API keys — leave blank for providers you don't use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Local Ollama (no key required)
OLLAMA_BASE_URL=http://localhost:11434

# CORS — comma-separated origins allowed to talk to the gateway
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Dashboard (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
